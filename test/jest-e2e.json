{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "setupFilesAfterEnv": ["<rootDir>/test/e2e/jest-e2e-setup.ts"],
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "testTimeout": 60000,
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
}
